# FastAPI & Server
FASTAPI_ENV=development
FASTAPI_DEBUG=True
HOST=0.0.0.0
PORT=8000

# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=sqlite:///./arth_agent.db

# ChromaDB
CHROMA_DB_DIR=./backend/knowledge/db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://0.0.0.0:5173

# Session Management
SESSION_TIMEOUT_MINUTES=120

# Tax & Financial Settings
INFLATION_RATE=0.06
SAFE_WITHDRAWAL_RATE=0.04
EXPECTED_MF_RETURN=0.11
PPF_RETURN=0.07
