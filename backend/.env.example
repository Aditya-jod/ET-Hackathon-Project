# FastAPI & Server Configuration
FASTAPI_ENV=
FASTAPI_DEBUG=
HOST=
PORT=

# LLM API Keys (Choose ONE option)
# Option 1: Groq (Free inference) - Get key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Anthropic Claude (Paid)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 3: Ollama (Local LLM)
# Download from https://ollama.ai
USE_OLLAMA=
OLLAMA_API_URL=

# Database Configuration
# Provide your database connection string (e.g., sqlite:///./name.db)
DATABASE_URL=

# Vector Database (ChromaDB)
CHROMA_DB_DIR=

# Security & CORS
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=

# Session Management
SESSION_TIMEOUT_MINUTES=

# Financial Calculation Settings
# Enter rates as decimals (e.g., 0.05 for 5%)
INFLATION_RATE=
SAFE_WITHDRAWAL_RATE=
EXPECTED_MF_RETURN=
PPF_RETURN=